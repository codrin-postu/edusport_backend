{
  "kind": "collectionType",
  "collectionName": "contact_submissions",
  "info": {
    "singularName": "contact-submission",
    "pluralName": "contact-submissions",
    "displayName": "Misc / Mesaj de contact",
    "description": "Mesaje trimise prin formularul de contact public"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {
    "content-manager": {
      "visible": true
    }
  },
  "attributes": {
    "name": {
      "type": "string",
      "required": true
    },
    "email": {
      "type": "email",
      "required": true
    },
    "phone": {
      "type": "string"
    },
    "reason": {
      "type": "enumeration",
      "enum": [
        "inscriere",
        "informatii-cursuri",
        "program",
        "tarife",
        "partenariat",
        "feedback",
        "altele"
      ],
      "required": true
    },
    "message": {
      "type": "text",
      "required": true,
      "maxLength": 5000
    },
    "triageStatus": {
      "type": "enumeration",
      "enum": ["new", "read", "replied", "archived"],
      "default": "new",
      "required": true
    },
    "internalNote": {
      "type": "text"
    },
    "submittedAt": {
      "type": "datetime"
    },
    "submitterIp": {
      "type": "string"
    },
    "userAgent": {
      "type": "string"
    }
  }
}
