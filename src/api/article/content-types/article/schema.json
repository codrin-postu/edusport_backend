{
  "kind": "collectionType",
  "collectionName": "articles",
  "info": {
    "singularName": "article",
    "pluralName": "articles",
    "displayName": "Misc / Articol",
    "description": "Articole de știri și evenimente"
  },
  "options": {
    "draftAndPublish": true
  },
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "title",
      "required": true
    },
    "description": {
      "type": "string",
      "maxLength": 300
    },
    "body": {
      "type": "blocks"
    },
    "gallery": {
      "type": "media",
      "multiple": true,
      "required": false,
      "allowedTypes": [
        "images"
      ]
    },
    "video": {
      "type": "json",
      "customField": "plugin::component-preview.video-embed",
      "required": false
    },
    "coverImage": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": [
        "images"
      ]
    },
    "category": {
      "type": "enumeration",
      "enum": [
        "evenimente",
        "anunturi",
        "general",
        "competitii",
        "tips"
      ],
      "required": true
    },
    "date": {
      "type": "date",
      "required": true
    },
    "eventDate": {
      "type": "datetime"
    },
    "eventLocation": {
      "type": "string"
    },
    "eventAdmissionInfo": {
      "type": "string"
    }
  }
}
