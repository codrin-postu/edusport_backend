{
  "kind": "collectionType",
  "collectionName": "sportspeople",
  "info": {
    "singularName": "sportsperson",
    "pluralName": "sportspeople",
    "displayName": "Club / Sportiv",
    "description": "Profil pentru sportivii clubului"
  },
  "options": {
    "draftAndPublish": true
  },
  "attributes": {
    "name": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "name",
      "required": true
    },
    "photo": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": ["images"]
    },
    "description": {
      "type": "text"
    },
    "showPublicPage": {
      "type": "boolean",
      "default": false,
      "required": true
    },
    "activeSince": {
      "type": "date"
    },
    "favoriteMoves": {
      "type": "json"
    },
    "hobbies": {
      "type": "json"
    },
    "gallery": {
      "type": "media",
      "multiple": true,
      "required": false,
      "allowedTypes": ["images"]
    },
    "disciplines": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::discipline.discipline"
    },
    "coach": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "api::team-member.team-member"
    },
    "choreographers": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::team-member.team-member"
    },
    "careerGoal": {
      "type": "text",
      "maxLength": 300
    },
    "seasons": {
      "type": "component",
      "repeatable": true,
      "component": "sportsperson.program-season"
    }
  }
}
