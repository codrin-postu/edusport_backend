{
  "kind": "singleType",
  "collectionName": "announcements",
  "info": {
    "singularName": "announcement",
    "pluralName": "announcements",
    "displayName": "Anunț Popup",
    "description": "Anunț afișat ca popup pe site. Activați comutatorul pentru a afișa anunțul vizitatorilor."
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {
    "content-manager": {
      "visible": true
    }
  },
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "isActive": {
      "type": "boolean",
      "default": false,
      "customField": "plugin::component-preview.announcement-is-active"
    },
    "expiresAt": {
      "type": "datetime",
      "customField": "plugin::component-preview.announcement-expires-at"
    },
    "announceContent": {
      "type": "json",
      "customField": "plugin::component-preview.announcement-content"
    }
  }
}
