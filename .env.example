# EduSport Strapi backend — environment template.
#
# Copy to .env for local dev or to .env.production for the prod stack.
# Generate every secret with:  openssl rand -base64 32
# APP_KEYS expects a comma-separated list — generate two and join them.

# ----- Runtime -----
NODE_ENV=production
HOST=0.0.0.0
PORT=1337

# ----- Strapi secrets ----- (Generate: openssl rand -base64 32)
APP_KEYS=replace,replace
API_TOKEN_SALT=replace
ADMIN_JWT_SECRET=replace
TRANSFER_TOKEN_SALT=replace
JWT_SECRET=replace
ENCRYPTION_KEY=replace

# ----- Database -----
DATABASE_CLIENT=postgres
DATABASE_HOST=postgres
DATABASE_PORT=5432
DATABASE_NAME=strapi
DATABASE_USERNAME=strapi
DATABASE_PASSWORD=replace
DATABASE_SSL=false

# ----- CORS / frontend integration -----
# Comma-separated list of allowed origins for production.
FRONTEND_ORIGIN=https://scoaladepatinaj.com
