{
  "name": "backend",
  "version": "0.1.0",
  "private": true,
  "description": "A Strapi application",
  "scripts": {
    "build": "strapi build",
    "console": "strapi console",
    "deploy": "strapi deploy",
    "dev": "strapi develop",
    "develop": "strapi develop",
    "seed:example": "node ./scripts/seed.js",
    "seed:regulations": "docker exec strapi_app node scripts/seed-regulations.js",
    "seed:pricing": "docker exec strapi_app node scripts/seed-pricing.js",
    "seed:cursuri-page": "docker exec strapi_app node scripts/seed-cursuri-page.js",
    "seed:content": "docker exec strapi_app node scripts/seed-content.js",
    "seed:homepage": "docker exec strapi_app node scripts/seed-homepage.js",
    "start": "strapi start",
    "strapi": "strapi",
    "upgrade": "npx @strapi/upgrade latest",
    "upgrade:dry": "npx @strapi/upgrade latest --dry",
    "docker:restart": "docker exec strapi_app rm -rf .strapi build node_modules/.vite && docker exec strapi_app npm run build && docker compose restart strapi",
    "docker:reset": "docker compose down && docker compose up -d --build",
    "docker:logs": "docker compose logs --tail=80 -f strapi"
  },
